# ============================================================
# Skin&Body — .htaccess (Apache)
# Static export from Next.js. Assumes mod_rewrite, mod_headers,
# mod_deflate, mod_expires are enabled on the host.
# ============================================================

Options -Indexes

# --- 0. Block access to hidden / backup / env files ---
<FilesMatch "(^\.(?!well-known)|\.DS_Store|\.env|\.git|\.bak|\.old|\.orig|\.swp|~)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # --- 0. Анти-скрейпинг ---
    # Блокируем типовые инструменты скрейпинга и агрессивные SEO-краулеры.
    # ВАЖНО: поисковики (Googlebot/YandexBot/Bingbot) НЕ перечислены — их не трогаем.
    # Это отсекает «ленивых» парсеров; для серьёзной защиты — Cloudflare (WAF/rate-limit).
    RewriteCond %{HTTP_USER_AGENT} (curl|wget|python-requests|python-urllib|aiohttp|httpx|scrapy|httrack|libwww-perl|go-http-client|node-fetch|axios|phantomjs|headlesschrome|nikto|sqlmap|masscan|zgrab) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|PetalBot|DataForSeoBot|Bytespider|BLEXBot) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} ^$
    RewriteRule .* - [F,L]

    # Прямой HTTP-доступ к дампу каталога закрыт (нужен только серверному PHP,
    # который читает его с диска). Закрывает «весь каталог одним файлом».
    RewriteRule ^catalog\.json$ - [F,L]

    # Лог honeypot-ловушки (trap.php) недоступен по HTTP.
    RewriteRule ^scrapers\.log$ - [F,L]

    # --- 1. HTTPS + non-www ---
    # Force HTTPS. REG.RU runs nginx in front of Apache — nginx terminates SSL
    # and forwards as HTTP, so %{HTTPS} is always "off" on Apache. Use the
    # X-Forwarded-Proto header that nginx sets to determine the real scheme.
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # www → non-www
    RewriteCond %{HTTP_HOST} ^www\.skinandbody\.ru$ [NC]
    RewriteRule ^ https://skinandbody.ru%{REQUEST_URI} [R=301,L]

    # --- 2. Page consolidations (301) ---
    # /laser/* → /epilation/ — лазерная эпиляция теперь живёт на /epilation/.
    # Покрывает /laser, /laser/, /laser/index.php и любой /laser/<что-угодно>.
    # Должно стоять ДО legacy-PHP правила ниже, иначе будет двойной редирект
    # /laser/index.php → /laser/ → /epilation/.
    RewriteRule ^laser(/.*)?$ /epilation/ [R=301,L]

    # --- 3. Legacy PHP URLs → clean paths (301) ---
    # /index.php → /
    RewriteRule ^index\.php/?$ / [R=301,L]

    # /<folder>/index.php → /<folder>/
    RewriteRule ^(cleansing|depilation|document|ems|epilation|lpg|microcurrenttherapy|peelings|privacy|rflifting|vacuum)/index\.php/?$ /$1/ [R=301,L]

    # Legacy /page/N pagination (if it was indexed) → home
    RewriteRule ^page/[0-9]+/?$ / [R=301,L]
</IfModule>

# --- 4. Caching ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"

    # HTML/data — always revalidate. Old HTML can reference deleted Next chunks
    # and leave mobile browsers with a half-broken site after redeploy.
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType application/xml               "access plus 0 seconds"
    ExpiresByType application/json              "access plus 0 seconds"

    # Assets — long (hashed in filename by Next.js)
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType application/x-javascript      "access plus 1 year"
    ExpiresByType text/javascript               "access plus 1 year"

    # Images
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType application/font-woff         "access plus 1 year"
    ExpiresByType application/font-woff2        "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control fallback if mod_expires not available
    <FilesMatch "\.(css|js|webp|png|jpe?g|svg|ico|woff2?|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "\.(html|json|xml)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
        # Temporary cache purge wave for browsers that support Clear-Site-Data.
        # Remove after users have picked up the fixed build to avoid extra reload cost.
        Header always set Clear-Site-Data "\"cache\""
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS only when actually on HTTPS (via X-Forwarded-Proto for nginx proxy)
    SetEnvIfNoCase X-Forwarded-Proto "https" HTTPS=on
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Content Security Policy — whitelist Yandex.Metrika (.ru + .com), yclients, Telegram, Google Fonts
    # Yandex.Metrika may switch from mc.yandex.ru to mc.yandex.com for non-RU IPs.
    # yclients widget loads both JS and CSS from *.yclients.com.
    Header always set Content-Security-Policy "default-src 'self'; \
script-src 'self' 'unsafe-inline' https://mc.yandex.ru https://mc.yandex.com https://*.yclients.com; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.yclients.com; \
font-src 'self' data: https://fonts.gstatic.com https://*.yclients.com; \
img-src 'self' data: https: blob:; \
connect-src 'self' https://mc.yandex.ru https://mc.yandex.com https://*.yclients.com wss://mc.yandex.ru wss://mc.yandex.com; \
frame-src https://mc.yandex.ru https://mc.yandex.com https://*.yclients.com https://yandex.ru https://*.yandex.ru; \
object-src 'none'; \
base-uri 'self'; \
frame-ancestors 'self'; \
form-action 'self';"

    # Remove server signature
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# --- 5. GZIP compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# --- 6. MIME types ---
<IfModule mod_mime.c>
    AddType image/webp                 .webp
    AddType image/svg+xml              .svg
    AddType application/json           .json
    AddType font/woff                  .woff
    AddType font/woff2                 .woff2
</IfModule>

# --- 7. Error pages ---
ErrorDocument 404 /404.html
