# Локальная разработка (.env.local). В репозиторий НЕ коммитится.
# Нужны только для dev-режима форм: при `pnpm dev` заявки уходят напрямую
# в Telegram Bot API. В production используется /sendform.php (токен на сервере).

# Токен тестового Telegram-бота
NEXT_PUBLIC_TG_BOT_TOKEN=
# ID тестового чата/канала для заявок
NEXT_PUBLIC_TG_CHAT_ID=
